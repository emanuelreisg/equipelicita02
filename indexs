<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EQUIPE LICITA 02 - Sistema de Alimentação</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- SheetJS for Excel export -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

    <!-- Custom Config for Tailwind -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#f0f9ff',
                            100: '#e0f2fe',
                            500: '#0ea5e9',
                            600: '#0284c7',
                            700: '#0369a1',
                            800: '#075985',
                            900: '#0c4a6e',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .fade-in {
            animation: fadeIn 0.3s ease-in-out;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        /* Glassmorphism for cards */
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        /* Bell ring animation */
        .bell-ringing {
            animation: bellRing 0.6s ease-in-out;
        }
        @keyframes bellRing {
            0%, 100% { transform: rotate(0deg); }
            10%, 30% { transform: rotate(-10deg); }
            20%, 40% { transform: rotate(10deg); }
            50% { transform: rotate(0deg); }
        }
        /* Toggle checkbox style */
        .toggle-checkbox {
            appearance: none;
            width: 44px;
            height: 24px;
            background: #cbd5e1;
            border-radius: 12px;
            position: relative;
            cursor: pointer;
            transition: background 0.3s;
        }
        .toggle-checkbox:checked {
            background: #0ea5e9;
        }
        .toggle-checkbox::before {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: white;
            top: 2px;
            left: 2px;
            transition: transform 0.3s;
        }
        .toggle-checkbox:checked::before {
            transform: translateX(20px);
        }
    </style>
</head>
<body class="bg-slate-100 text-slate-800 min-h-screen font-sans">

    <!-- Login Screen -->
    <div id="login-screen" class="fixed inset-0 bg-gradient-to-br from-brand-600 to-brand-800 flex items-center justify-center z-50">
        <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md">
            <div class="text-center mb-8">
                <div class="inline-block p-4 bg-brand-100 rounded-full mb-4">
                    <i data-lucide="shield-check" class="w-12 h-12 text-brand-600"></i>
                </div>
                <h1 class="text-2xl font-bold text-slate-800 mb-2">EQUIPE LICITA 02</h1>
                <p class="text-slate-500 text-sm">Sistema de Gestão de Processos Licitatórios</p>
            </div>
            
            <!-- Login Form -->
            <form id="login-form" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Usuário</label>
                    <div class="relative">
                        <i data-lucide="user" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                        <input type="text" id="login-username" placeholder="Digite seu usuário" class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:bg-white transition-all" required>
                    </div>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Senha</label>
                    <div class="relative">
                        <i data-lucide="lock" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                        <input type="password" id="login-password" placeholder="Digite sua senha" class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:bg-white transition-all" required>
                    </div>
                </div>
                
                <div id="login-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
                    <i data-lucide="alert-circle" class="w-4 h-4 inline mr-2"></i>
                    <span id="login-error-message">Usuário ou senha incorretos</span>
                </div>
                
                <button type="submit" class="w-full bg-brand-600 hover:bg-brand-700 text-white font-medium py-3 rounded-lg transition-colors shadow-sm flex items-center justify-center gap-2">
                    <i data-lucide="log-in" class="w-5 h-5"></i>
                    Entrar
                </button>
                
                <div class="text-center">
                    <button type="button" onclick="showRegisterForm()" class="text-sm text-brand-600 hover:text-brand-700 hover:underline font-medium">
                        Não tem uma conta? Criar conta
                    </button>
                </div>
            </form>
            
            <!-- Register Form -->
            <form id="register-form" class="space-y-4 hidden">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Nome Completo</label>
                    <div class="relative">
                        <i data-lucide="user" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                        <input type="text" id="register-fullname" placeholder="Digite seu nome completo" class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:bg-white transition-all" required>
                    </div>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Usuário</label>
                    <div class="relative">
                        <i data-lucide="at-sign" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                        <input type="text" id="register-username" placeholder="Escolha um nome de usuário" class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:bg-white transition-all" required>
                    </div>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Senha</label>
                    <div class="relative">
                        <i data-lucide="lock" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                        <input type="password" id="register-password" placeholder="Crie uma senha" class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:bg-white transition-all" required>
                    </div>
                    <p class="text-xs text-slate-500 mt-1">Mínimo de 6 caracteres</p>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Confirmar Senha</label>
                    <div class="relative">
                        <i data-lucide="lock" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                        <input type="password" id="register-password-confirm" placeholder="Confirme sua senha" class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:bg-white transition-all" required>
                    </div>
                </div>
                
                <div id="register-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
                    <i data-lucide="alert-circle" class="w-4 h-4 inline mr-2"></i>
                    <span id="register-error-message">Erro ao criar conta</span>
                </div>
                
                <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white font-medium py-3 rounded-lg transition-colors shadow-sm flex items-center justify-center gap-2">
                    <i data-lucide="user-plus" class="w-5 h-5"></i>
                    Criar Conta
                </button>
                
                <div class="text-center">
                    <button type="button" onclick="showLoginForm()" class="text-sm text-brand-600 hover:text-brand-700 hover:underline font-medium">
                        Já tem uma conta? Fazer login
                    </button>
                </div>
            </form>
            
            <div class="mt-6 pt-6 border-t border-slate-200 text-center">
                <p class="text-xs text-slate-500">Desenvolvido por <span class="font-semibold">EMANUEL REIS</span></p>
            </div>
        </div>
    </div>

    <!-- Sidebar / Mobile Menu Overlay -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden" onclick="toggleSidebar()"></div>

    <div class="flex h-screen overflow-hidden">
        
        <!-- Sidebar -->
        <aside id="sidebar" class="fixed lg:static inset-y-0 left-0 z-50 w-64 bg-slate-900 text-white transform -translate-x-full lg:translate-x-0 transition-transform duration-300 flex flex-col shadow-xl">
            <div class="p-6 border-b border-slate-800 flex items-center justify-between">
                <div>
                    <h1 class="text-xl font-bold tracking-wider text-brand-500">EQUIPE</h1>
                    <h2 class="text-sm font-light tracking-widest text-slate-400">LICITA 02</h2>
                </div>
                <button onclick="toggleSidebar()" class="lg:hidden text-slate-400 hover:text-white">
                    <i data-lucide="x"></i>
                </button>
            </div>

            <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
                <button onclick="navigateTo('dashboard')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors text-left group active-nav">
                    <i data-lucide="layout-dashboard" class="w-5 h-5 group-hover:text-brand-500 transition-colors"></i>
                    <span class="font-medium">Dashboard</span>
                </button>
                <button onclick="navigateTo('spreadsheet')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors text-left group">
                    <i data-lucide="table" class="w-5 h-5 group-hover:text-brand-500 transition-colors"></i>
                    <span class="font-medium">Planilha Alimentação</span>
                </button>
                <button onclick="navigateTo('reports')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors text-left group">
                    <i data-lucide="bar-chart-3" class="w-5 h-5 group-hover:text-brand-500 transition-colors"></i>
                    <span class="font-medium">Relatórios</span>
                </button>
                <button onclick="navigateTo('process-details')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors text-left group">
                    <i data-lucide="file-search" class="w-5 h-5 group-hover:text-brand-500 transition-colors"></i>
                    <span class="font-medium">Detalhar Processos</span>
                </button>
                <button onclick="navigateTo('finalizados')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors text-left group">
                    <i data-lucide="check-circle" class="w-5 h-5 group-hover:text-brand-500 transition-colors"></i>
                    <span class="font-medium">Processos Finalizados</span>
                </button>
                <button onclick="navigateTo('items')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors text-left group">
                    <i data-lucide="package" class="w-5 h-5 group-hover:text-brand-500 transition-colors"></i>
                    <span class="font-medium">Itens</span>
                </button>
                <button onclick="navigateTo('legislacoes')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors text-left group">
                    <i data-lucide="book-open" class="w-5 h-5 group-hover:text-brand-500 transition-colors"></i>
                    <span class="font-medium">Legislações Pertinentes</span>
                </button>
                <button onclick="navigateTo('settings')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors text-left group">
                    <i data-lucide="settings" class="w-5 h-5 group-hover:text-brand-500 transition-colors"></i>
                    <span class="font-medium">Configurações</span>
                </button>
            </nav>

            <div class="p-4 border-t border-slate-800">
                <div class="flex items-center gap-3 px-4 py-2">
                    <div class="w-8 h-8 rounded-full bg-brand-600 flex items-center justify-center text-white font-bold text-sm">EL</div>
                    <div>
                        <p class="text-sm font-medium">Admin User</p>
                        <p class="text-xs text-slate-500">Gestor</p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col h-screen overflow-hidden bg-slate-50 relative">
            
            <!-- Top Header -->
            <header class="bg-white border-b border-slate-200 h-16 flex items-center justify-between px-6 shadow-sm z-30">
                <button onclick="toggleSidebar()" class="lg:hidden p-2 text-slate-600 hover:bg-slate-100 rounded-md">
                    <i data-lucide="menu"></i>
                </button>
                
                <div class="flex items-center gap-4 ml-auto">
                    <div class="relative">
                        <button id="notification-bell" onclick="toggleNotificationPanel()" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-full transition-colors relative">
                            <i data-lucide="bell" class="w-5 h-5"></i>
                            <span id="bell-badge" class="absolute top-1 right-1 w-4 h-4 bg-red-500 rounded-full border border-white text-white text-xs flex items-center justify-center font-bold hidden">0</span>
                        </button>
                        <!-- Notifications Dropdown Panel -->
                        <div id="notification-panel" class="hidden fixed right-4 top-16 w-80 bg-white rounded-lg shadow-2xl border border-slate-200 z-40">
                            <div class="p-4 border-b border-slate-200 flex items-center justify-between">
                                <h3 class="font-semibold text-slate-800">Últimas Ações</h3>
                                <button onclick="closeNotificationPanel()" class="text-slate-400 hover:text-slate-600">
                                    <i data-lucide="x" class="w-4 h-4"></i>
                                </button>
                            </div>
                            <div id="notifications-list" class="max-h-96 overflow-y-auto">
                                <div class="p-4 text-center text-slate-400 text-sm">Nenhuma ação registrada.</div>
                            </div>
                        </div>
                    </div>
                    <button onclick="openSessionModal()" class="bg-brand-600 hover:bg-brand-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors shadow-sm flex items-center gap-2">
                        <i data-lucide="plus-circle" class="w-4 h-4"></i>
                        Novo Registro de Sessão
                    </button>
                </div>
            </header>

            <!-- Scrollable Content Area -->
            <div id="content-area" class="flex-1 overflow-y-auto p-6 lg:p-8 relative">
                
                <!-- View: Dashboard -->
                <section id="view-dashboard" class="view-section fade-in space-y-6">
                    <div class="mb-8">
                        <h2 class="text-2xl font-bold text-slate-800">Visão Geral</h2>
                        <p class="text-slate-500">Bem-vindo ao sistema EQUIPE LICITA 02.</p>
                    </div>

                    <!-- Stats Cards -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                        <div class="glass-card p-6 rounded-xl shadow-sm border-l-4 border-brand-500">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-slate-500 text-sm font-medium">PROCESSOS NA CAIXA</h3>
                                <div class="p-2 bg-brand-50 rounded-lg text-brand-600">
                                    <i data-lucide="inbox" class="w-5 h-5"></i>
                                </div>
                            </div>
                            <p class="text-2xl font-bold text-slate-800" id="dash-processos-caixa">0</p>
                            <p class="text-xs text-slate-400 mt-1">Contagem atual</p>
                        </div>

                        <div class="glass-card p-6 rounded-xl shadow-sm border-l-4 border-orange-500">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-slate-500 text-sm font-medium">PROCESSOS EM OUTRO SETOR</h3>
                                <div class="p-2 bg-orange-50 rounded-lg text-orange-600">
                                    <i data-lucide="building-2" class="w-5 h-5"></i>
                                </div>
                            </div>
                            <p class="text-2xl font-bold text-slate-800" id="dash-processos-outro">0</p>
                            <p class="text-xs text-slate-400 mt-1">Registros atuais</p>
                        </div>
                        
                        <div class="glass-card p-6 rounded-xl shadow-sm border-l-4 border-green-500">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-slate-500 text-sm font-medium">TOTAL DE PROCESSOS</h3>
                                <div class="p-2 bg-green-50 rounded-lg text-green-600">
                                    <i data-lucide="target" class="w-5 h-5"></i>
                                </div>
                            </div>
                            <p class="text-2xl font-bold text-slate-800" id="dash-total-processos">0</p>
                            <p class="text-xs text-slate-400 mt-1">Soma dos dois primeiros</p>
                        </div>

                        <div id="finalizados-card" class="glass-card p-6 rounded-xl shadow-sm border-l-4 border-emerald-500">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-slate-500 text-sm font-medium">PROCESSOS FINALIZADOS</h3>
                                <div class="p-2 bg-emerald-50 rounded-lg text-emerald-600">
                                    <i data-lucide="check" class="w-5 h-5"></i>
                                </div>
                            </div>
                            <p id="dash-processos-finalizados" class="text-2xl font-bold text-slate-800">0</p>
                            <p class="text-xs text-slate-400 mt-1">Contagem de processos finalizados</p>
                            <div class="border-t border-slate-200 mt-4 pt-4">
                                <p class="text-xs text-slate-500 font-medium mb-2">ECONOMIA TOTAL</p>
                                <p id="dash-economia-total" class="text-xl font-bold text-green-600">R$ 0,00</p>
                            </div>
                        </div>

                        <div class="glass-card p-6 rounded-xl shadow-sm border-l-4 border-purple-500 md:col-span-2 lg:col-span-4">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-slate-500 text-sm font-medium">SESSÕES MARCADAS</h3>
                                <div>
                                    <input id="sessions-month-input" type="month" class="bg-slate-50 border border-slate-200 rounded-md px-2 py-1 text-sm">
                                </div>
                            </div>
                            <div id="sessions-list" class="text-sm text-slate-700 max-h-72 overflow-y-auto space-y-2">
                                <!-- sessions will be rendered here -->
                            </div>
                            <p class="text-xs text-slate-400 mt-2">Selecione o mês para visualizar as sessões marcadas.</p>
                        </div>
                    </div>

                    <!-- Quick Actions Grid -->
                    <h3 class="text-lg font-semibold text-slate-700 mb-4">Ações Rápidas</h3>
                    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                        <button onclick="openProcessModal()" class="p-6 bg-white rounded-xl shadow-sm hover:shadow-md transition-all border border-slate-100 hover:border-brand-200 group text-center flex flex-col items-center gap-3">
                            <div class="w-12 h-12 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i data-lucide="coffee" class="w-6 h-6"></i>
                            </div>
                            <span class="font-medium text-slate-700">NOVO PROCESSO</span>
                        </button>

                        <button onclick="navigateTo('reports')" class="p-6 bg-white rounded-xl shadow-sm hover:shadow-md transition-all border border-slate-100 hover:border-brand-200 group text-center flex flex-col items-center gap-3">
                            <div class="w-12 h-12 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i data-lucide="bar-chart-3" class="w-6 h-6"></i>
                            </div>
                            <span class="font-medium text-slate-700">RELATÓRIOS</span>
                        </button>

                        <button onclick="navigateTo('process-details')" class="p-6 bg-white rounded-xl shadow-sm hover:shadow-md transition-all border border-slate-100 hover:border-brand-200 group text-center flex flex-col items-center gap-3">
                            <div class="w-12 h-12 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i data-lucide="file-search" class="w-6 h-6"></i>
                            </div>
                            <span class="font-medium text-slate-700">DETALHAR PROCESSOS</span>
                        </button>
                        
                        <button onclick="navigateTo('spreadsheet')" class="p-6 bg-white rounded-xl shadow-sm hover:shadow-md transition-all border border-slate-100 hover:border-brand-200 group text-center flex flex-col items-center gap-3">
                            <div class="w-12 h-12 rounded-full bg-slate-100 text-slate-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i data-lucide="file-spreadsheet" class="w-6 h-6"></i>
                            </div>
                            <span class="font-medium text-slate-700">Ver Planilhas</span>
                        </button>
                    </div>
                </section>

                <!-- View: Spreadsheet -->
                <section id="view-spreadsheet" class="view-section hidden fade-in space-y-6">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
                        <div>
                            <h2 class="text-2xl font-bold text-slate-800">Planilha de Processos</h2>
                            <p class="text-slate-500">Gerencie os processos cadastrados. Você pode importar e exportar a planilha em formato CSV/Excel para trabalhar externamente.</p>
                        </div>
                        <div class="flex gap-2">
                            <button onclick="exportCSV()" class="px-4 py-2 bg-white border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 flex items-center gap-2">
                                <i data-lucide="download" class="w-4 h-4"></i> Exportar
                            </button>
                            <button onclick="triggerImport()" class="px-4 py-2 bg-white border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 flex items-center gap-2">
                                <i data-lucide="upload" class="w-4 h-4"></i> Importar
                            </button>
                            <button onclick="openProcessModal()" class="px-4 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-700 flex items-center gap-2 shadow-sm">
                                <i data-lucide="plus" class="w-4 h-4"></i> Adicionar Processo
                            </button>
                            <input type="file" accept=".csv" id="import-file" class="hidden" onchange="importCSV(event)">
                        </div>
                    </div>

                    <!-- Filters -->
                    <div class="bg-white p-4 rounded-xl shadow-sm border border-slate-200 mb-6 flex flex-wrap gap-4 items-end">
                        <div class="flex-1 min-w-[200px]">
                            <label class="block text-xs font-medium text-slate-500 mb-1">Buscar</label>
